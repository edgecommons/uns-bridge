# Copy to .env and edit as needed: `cp .env.example .env`
# All variables are optional — docker-compose.yml's defaults match the local dual-EMQX dev layout
# documented in ../README.md and ../../README.md (device broker :1883, site broker :1884/:8884).

# --- image ---
SITE_IMAGE_TAG=5.8.2
DEVICE_IMAGE_TAG=5.8.2

# --- site broker ports (host-side) ---
# Local-dev defaults (1884/8884/18084) so this sits BESIDE an existing device-local broker
# (edgecommons-emqx on :1883/:8883/:18083) without a port clash — see ../README.md.
SITE_MQTT_PORT=1884
SITE_MQTTS_PORT=8884
SITE_DASHBOARD_PORT=18084

# PRODUCTION (single-purpose site-gateway host, no device broker sharing it): uncomment to use the
# standard MQTT ports instead, and firewall/disable 1883 at the host level (§4.1).
# SITE_MQTT_PORT=1883
# SITE_MQTTS_PORT=8883
# SITE_DASHBOARD_PORT=18083

# --- device broker ports (host-side; only used with `--profile dual`) ---
DEVICE_MQTT_PORT=1883
DEVICE_DASHBOARD_PORT=18083
